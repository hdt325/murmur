{
  "name": "murmur",
  "version": "1.0.0",
  "description": "Voice interface for Claude Code",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "release:mac": "electron-builder --mac --publish always",
    "release:win": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.murmur.app",
    "productName": "Murmur",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "hdt325",
      "repo": "murmur",
      "releaseType": "release"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "icons/icon.icns",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    },
    "files": [
      "main.js",
      "preload.js",
      "loading.html",
      "icons/**/*"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "murmur",
        "filter": [
          "server.ts",
          "index.html",
          "manifest.json",
          "settings.json",
          "package.json",
          "package-lock.json",
          "terminal/**/*",
          "site/**/*",
          "tsconfig.json"
        ]
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
